{
  "ruleset_version": "2026.03.04-cerner-fhir",
  "vendor": "oracle-health",
  "vendor_name": "Oracle Health (formerly Cerner Corporation)",
  "export_type": "FHIR",
  "fhir_target": "R4",
  "description": "Oracle Health FHIR R4 API (Ignite APIs) - Native FHIR export from Millennium EHR",
  "author": "Health Data Alchemist",
  "last_updated": "2026-03-04",
  "official_spec": "https://fhir.cerner.com/",
  "api_base_url": "https://fhir-myrecord.cerner.com/r4/{tenant-id}",
  "spec_version": "FHIR R4 (4.0.1)",
  "supports_uscdi": ["v3", "v4"],
  "authentication": {
    "type": "OAuth 2.0",
    "smart_on_fhir": true,
    "patient_access": true
  },
  "files": [
    "10_patient_fhir.yaml",
    "20_encounter_fhir.yaml",
    "30_condition_fhir.yaml",
    "40_medication_fhir.yaml",
    "50_observation_fhir.yaml",
    "60_document_fhir.yaml",
    "70_allergy_fhir.yaml",
    "80_immunization_fhir.yaml",
    "90_procedure_fhir.yaml"
  ],
  "supported_resources": {
    "Patient": {
      "rules": "10_patient_fhir.yaml",
      "resource_type": "Patient",
      "description": "Patient demographics and identifiers",
      "endpoint": "/Patient/{id}",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient",
      "search_params": ["_id", "identifier", "name", "birthdate"]
    },
    "Encounter": {
      "rules": "20_encounter_fhir.yaml",
      "resource_type": "Encounter",
      "description": "Patient encounters and visits",
      "endpoint": "/Encounter",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-encounter",
      "search_params": ["patient", "date", "type", "status"]
    },
    "Condition": {
      "rules": "30_condition_fhir.yaml",
      "resource_type": "Condition",
      "description": "Problems and diagnoses",
      "endpoint": "/Condition",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-condition",
      "search_params": ["patient", "category", "clinical-status", "onset-date"]
    },
    "MedicationRequest": {
      "rules": "40_medication_fhir.yaml",
      "resource_type": "MedicationRequest",
      "description": "Medication orders and prescriptions",
      "endpoint": "/MedicationRequest",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-medicationrequest",
      "search_params": ["patient", "status", "intent", "authoredon"]
    },
    "Observation": {
      "rules": "50_observation_fhir.yaml",
      "resource_type": "Observation",
      "description": "Lab results, vital signs, and clinical observations",
      "endpoint": "/Observation",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-observation-lab",
      "search_params": ["patient", "category", "code", "date"]
    },
    "DocumentReference": {
      "rules": "60_document_fhir.yaml",
      "resource_type": "DocumentReference",
      "description": "Clinical documents and notes",
      "endpoint": "/DocumentReference",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-documentreference",
      "search_params": ["patient", "type", "date", "category"]
    },
    "AllergyIntolerance": {
      "rules": "70_allergy_fhir.yaml",
      "resource_type": "AllergyIntolerance",
      "description": "Allergies and adverse reactions",
      "endpoint": "/AllergyIntolerance",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-allergyintolerance",
      "search_params": ["patient", "clinical-status"]
    },
    "Immunization": {
      "rules": "80_immunization_fhir.yaml",
      "resource_type": "Immunization",
      "description": "Immunization history",
      "endpoint": "/Immunization",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-immunization",
      "search_params": ["patient", "date", "status"]
    },
    "Procedure": {
      "rules": "90_procedure_fhir.yaml",
      "resource_type": "Procedure",
      "description": "Procedures performed",
      "endpoint": "/Procedure",
      "us_core_profile": "http://hl7.org/fhir/us/core/StructureDefinition/us-core-procedure",
      "search_params": ["patient", "date", "code", "status"]
    }
  },
  "requirements": {
    "min_app_version": "0.1.0",
    "parser": "native",
    "validation": "fhir-validator"
  },
  "validation": {
    "fhir_version": "4.0.1",
    "profile_validation": true,
    "us_core_compliance": true,
    "required_elements": {
      "Patient": ["identifier", "name", "gender", "birthDate"],
      "Observation": ["status", "code", "subject"]
    }
  },
  "bulk_export": {
    "supported": true,
    "endpoint": "/$export",
    "format": "ndjson",
    "parameters": ["_type", "_since", "_outputFormat"]
  },
  "notes": [
    "Oracle Health FHIR API provides native FHIR R4 resources",
    "Requires OAuth 2.0 authentication for API access",
    "Supports SMART on FHIR for patient-mediated access",
    "Minimal mapping required since data is already in FHIR format",
    "May include Cerner-specific extensions",
    "HealtheLife patient portal provides access to FHIR API"
  ]
}
