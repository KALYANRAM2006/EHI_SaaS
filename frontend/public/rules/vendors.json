  "format_capabilities": {
    "TSV": {
      "parsing_complexity": "medium",
      "standardization": "vendor-specific",
      "requires_mapping": true,
      "typical_vendors": ["Epic"]
    },
    "FHIR": {
      "parsing_complexity": "low",
      "standardization": "HL7 FHIR R4",
      "requires_mapping": false,
      "typical_vendors": ["Epic", "Cerner", "Allscripts", "MEDITECH", "athenahealth"]
    },
    "CCDA": {
      "parsing_complexity": "high",
      "standardization": "HL7 C-CDA R2.1",
      "requires_mapping": true,
      "typical_vendors": ["All EHR systems"]
    },
    "SQL": {
      "parsing_complexity": "high",
      "standardization": "vendor-specific",
      "requires_mapping": true,
      "typical_vendors": ["Oracle Health/Cerner"]
    }
  },
  "deployment_strategy": {
    "phase_1_mvp": ["epic-tsv", "ccda-r2"],
    "phase_2_expansion": ["cerner-fhir", "allscripts-fhir", "epic-fhir"],
    "phase_3_comprehensive": ["meditech-fhir", "athena-fhir", "cerner-sql"]
  },
  "notes": [
    "All rulesets map vendor-specific formats to FHIR R4 resources",
    "YAML rules stored in frontend /public/rules/ directory per architecture",
    "No PHI processed on server - all normalization happens client-side",
    "Market share data from KLAS Research 2024 EMR Market Share Report",
    "Official vendor specifications retrieved March 4, 2026"
  ]
}
