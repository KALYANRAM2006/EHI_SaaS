        {
          "type": "FHIR",
          "format_id": "epic-fhir",
          "description": "Epic on FHIR API Export",
          "manifest": "/rules/epic-fhir/manifest.json",
          "official_spec": "https://fhir.epic.com/",
          "supports_uscdi": ["v3", "v4", "v5"],
          "fhir_target": "R4",
          "notes": "Epic FHIR API supports patient-mediated access via SMART on FHIR."
