# CMS Prior Authorization API Configuration
# Get credentials from: https://www.cms.gov/apis

# CMS API Base URL
VITE_CMS_API_URL=https://api.cms.gov/fhir/v1

# CMS OAuth Token URL
VITE_CMS_TOKEN_URL=https://api.cms.gov/oauth2/token

# CMS API Client Credentials (OAuth 2.0)
VITE_CMS_CLIENT_ID=your_client_id_here
VITE_CMS_CLIENT_SECRET=your_client_secret_here

# Note: Keep credentials secure! Never commit .env file to git.
# The app will use mock data if credentials are not provided.
